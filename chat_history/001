684 `next` \u6307\u5411\u5934\u8282\u70b9\u3002\n\n#### \u7279\u70b9\uff1a\n- \u4ece\u4efb\u610f\u8282\u70b9\u51fa\u53d1\uff0c\u5747\u53ef\u904d\u5386\u6574\u4e2a\u94fe\u8868\uff1b\n- \u904d\u5386\u65f6\u5fc5\u987b\u8bbe\u7f6e\u7ec8\u6b62\u6761\u4ef6\uff08\u5982\u56de\u5230\u8d77\u59cb\u8282\u70b9\uff09\uff0c\u5426\u5219\u4f1a\u65e0\u9650\u5faa\u73af\uff1b\n- \u5e38\u7528\u4e8e\u9700\u8981\u5faa\u73af\u5904\u7406\u7684\u573a\u666f\uff0c\u4f8b\u5982\uff1a\u7ea6\u745f\u592b\u95ee\u9898\u3001\u64cd\u4f5c\u7cfb\u7edf\u4e2d\u7684\u8f6e\u8f6c\u8c03\u5ea6\uff08Round-Robin\uff09\u3001\u6e38\u620f\u56de\u5408\u5236\u7b49\u3002\n\n#### \u5355\u5411\u5faa\u73af\u94fe\u8868\u793a\u610f\u56fe\uff1a\n```\n  +------+\n  | head |\n  +--+---+\n     |\n     v\n  [A|\u00b7] --> [B|\u00b7] --> [C|\u00b7]\n   ^                    |\n   +--------------------+\n```\n\u5176\u4e2d\uff0cC \u7684 `next` \u6307\u5411 A\uff0c\u6784\u6210\u5faa\u73af\u3002\n\n#### Python \u7b80\u5355\u5b9e\u73b0\u793a\u4f8b\uff1a\n```python\nclass Node:\n    def __init__(self, data):\n        self.data = data\n        self.next = None\n\n# \u521b\u5efa\u5faa\u73af\u94fe\u8868\nhead = Node(1)\nsecond = Node(2)\nthird = Node(3)\n\nhead.next = second\nsecond.next = third\nthird.next = head  # \u5f62\u6210\u5faa\u73af\uff1a\u5c3e\u8282\u70b9\u6307\u5411\u5934\u8282\u70b9\n```\n\n> \u6ce8\u610f\uff1a\u64cd\u4f5c\u5faa\u73af\u94fe\u8868\u65f6\u9700\u5c0f\u5fc3\u907f\u514d\u65e0\u9650\u5faa\u73af\uff0c\u904d\u5386\u65f6\u901a\u5e38\u4ee5\u201c\u56de\u5230\u8d77\u59cb\u8282\u70b9\u201d\u4f5c\u4e3a\u7ed3\u675f\u6761\u4ef6\u3002\n\n--- \n\n\u4ee5\u4e0a\u5185\u5bb9\u6765\u6e90\u4e8e\u901a\u7528\u6570\u636e\u7ed3\u6784\u77e5\u8bc6\uff0c\u975e\u539f\u59cb\u53c2\u8003\u8d44\u6599\u3002", "additional_kwargs": {}, "response_metadata": {}, "type": "ai", "name": null, "id": null, "tool_calls": [], "invalid_tool_calls": [], "usage_metadata": null}}, {"type": "human", "data": {"content": "c#\u4ee3\u7801\u5b9e\u73b0", "additional_kwargs": {}, "response_metadata": {}, "type": "human", "name": null, "id": null}}, {"type": "ai", "data": {"content": "\u3010\u975e\u8d44\u6599\u4e2d\u7684\u7b54\u6848\u5982\u4e0b\u3011\n\n\u5728\u60a8\u63d0\u4f9b\u7684\u53c2\u8003\u8d44\u6599\u4e2d\uff0c**\u6ca1\u6709\u5305\u542b\u4efb\u4f55\u5173\u4e8e C# \u4ee3\u7801\u5b9e\u73b0\u5faa\u73af\u94fe\u8868\u7684\u5185\u5bb9**\u3002\u4ee5\u4e0b\u4e3a\u57fa\u4e8e\u901a\u7528\u7f16\u7a0b\u77e5\u8bc6\u7684 C# \u5faa\u73af\u94fe\u8868\u5b9e\u73b0\u793a\u4f8b\uff1a\n\n---\n\n### C# \u5355\u5411\u5faa\u73af\u94fe\u8868\u7b80\u5355\u5b9e\u73b0\n\n```csharp\nusing System;\n\n// \u5b9a\u4e49\u8282\u70b9\u7c7b\npublic class ListNode\n{\n    public int Data { get; set; }\n    public ListNode Next { get; set; }\n\n    public ListNode(int data)\n    {\n        Data = data;\n        Next = null;\n    }\n}\n\n// \u5faa\u73af\u94fe\u8868\u7c7b\npublic class CircularLinkedList\n{\n    private ListNode head;\n\n    public CircularLinkedList()\n    {\n        head = null;\n    }\n\n    // \u5728\u5c3e\u90e8\u63d2\u5165\u65b0\u8282\u70b9\n    public void InsertAtTail(int data)\n    {\n        ListNode newNode = new ListNode(data);\n\n        if (head == null)\n        {\n            head = newNode;\n            head.Next = head; // \u6307\u5411\u81ea\u5df1\uff0c\u5f62\u6210\u5faa\u73af\n        }\n        else\n        {\n            ListNode current = head;\n            // \u627e\u5230\u5c3e\u8282\u70b9\uff08\u5176 Next \u6307\u5411 head\uff09\n            while (current.Next != head)\n            {\n                current = current.Next;\n            }\n            current.Next = newNode;\n            newNode.Next = head; // \u65b0\u8282\u70b9\u6307\u5411\u5934\uff0c\u4fdd\u6301\u5faa\u73af\n        }\n    }\n\n    // \u6253\u5370\u94fe\u8868\uff08\u907f\u514d\u65e0\u9650\u5faa\u73af\uff09\n    public void PrintList()\n    {\n        if (head == null)\n        {\n            Console.WriteLine(\"\u94fe\u8868\u4e3a\u7a7a\");\n            return;\n        }\n\n        ListNode current = head;\n        do\n        {\n            Console.Write(current.Data + \" -> \");\n            current = current.Next;\n        } while (current != head); // \u56de\u5230\u8d77\u70b9\u5373\u505c\u6b62\n\n        Console.WriteLine(\"(\u56de\u5230\u5934\u90e8)\");\n    }\n}\n\n// \u4f7f\u7528\u793a\u4f8b\nclass Program\n{\n    static void Main()\n    {\n        CircularLinkedList list = new CircularLinkedList();\n        list.InsertAtTail(1);\n        list.InsertAtTail(2);\n        list.InsertAtTail(3);\n        list.PrintList(); \n        // \u8f93\u51fa: 1 -> 2 -> 3 -> (\u56de\u5230\u5934\u90e8)\n    }\n}\n```\n\n### \u8bf4\u660e\uff1a\n- \u8be5\u5b9e\u73b0\u4f7f\u7528 `do-while` \u5faa\u73af\u786e\u4fdd\u81f3\u5c11\u8bbf\u95ee\u4e00\u6b21\u5934\u8282\u70b9\uff1b\n- \u63d2\u5165\u64cd\u4f5c\u5728\u5c3e\u90e8\u8fdb\u884c\uff0c\u65f6\u95f4\u590d\u6742\u5ea6\u4e3a O(n)\uff1b\n- \u82e5\u9700\u9ad8\u6548\u5c3e\u63d2\uff0c\u53ef\u989d\u5916\u7ef4\u62a4\u4e00\u4e2a `tail` \u6307\u9488\u3002\n\n> \u6b64\u4ee3\u7801\u4e3a\u6807\u51c6\u6570\u636e\u7ed3\u6784\u6559\u5b66\u5b9e\u73b0\uff0c\u9002\u7528\u4e8e\u5b66\u4e60\u548c\u57fa\u7840\u5e94\u7528\u3002", "additional_kwargs": {}, "response_metadata": {}, "type": "ai", "name": null, "id": null, "tool_calls": [], "invalid_tool_calls": [], "usage_metadata": null}}]